#!/usr/bin/env bash
set -euo pipefail

REPO=""

if [[ "${1:-}" == "-R" ]]; then
    REPO="$2"
    shift 2
fi

ghr() {
    if [ -n "$REPO" ]; then
        gh -R "$REPO" "$@"
    else
        gh "$@"
    fi
}

CACHE_DIR="/tmp/ghi"
mkdir -p "$CACHE_DIR"

cache_file() {
    if [ -n "$REPO" ]; then
        echo "$CACHE_DIR/cache-${REPO//\//_}.json"
    else
        echo "$CACHE_DIR/cache-local.json"
    fi
}

issue_cache() {
    local CACHE
    CACHE=$(cache_file)
    echo "[INFO] Atualizando cache..." >&2
    ghr issue list --limit 200 --json number,title,body,labels,state > "$CACHE"
    date +%s > "${CACHE}.time"
}

cache_valid() {
    local CACHE
    CACHE=$(cache_file)

    if [ ! -f "$CACHE" ] || [ ! -f "${CACHE}.time" ]; then
        return 1
    fi

    local NOW
    NOW=$(date +%s)
    local LAST
    LAST=$(cat "${CACHE}.time")

    local AGE=$((NOW - LAST))
    [ "$AGE" -gt 300 ] && return 1

    return 0
}

tmp_file() {
    echo "/tmp/gh-issue-$1-$(date +%s).md"
}

cleanup_msg() {
    local file="$1"
    echo
    echo "[RECOVER] Arquivo salvo em: $file"
}

issue_list() {
    local CACHE
    CACHE=$(cache_file)

    if ! cache_valid; then
        issue_cache
    fi

    jq -r '
    .[]
    | "\(.number)\t\(.labels | map(.name) | join(","))\t\(.title)"
    ' "$CACHE" | column -t -s $'\t'
}

issue_preview() {
    local num="$1"
    local CACHE
    CACHE=$(cache_file)

    jq -r ".[] | select(.number==$num) |
    \"# \(.title)\n\nState: \(.state)\n\n\(.body)\n\nLabels: \(.labels | map(.name) | join(\", \"))\"" "$CACHE"
}

issue_view() {
    ghr issue view "$1"
}

issue_edit() {
    local issue="$1"
    TMP=$(tmp_file "$issue")   # TMP global para trap

    echo "[INFO] Temp file: $TMP"

    SUCCESS=0
    trap 'if [ "${SUCCESS:-0}" -eq 0 ]; then cleanup_msg "$TMP"; fi' EXIT

    DATA=$(ghr issue view "$issue" --json title,body,labels)

    TITLE=$(echo "$DATA" | jq -r .title)
    BODY=$(echo "$DATA" | jq -r .body)
    CURRENT_LABELS=$(echo "$DATA" | jq -r '.labels[].name')
    ALL_LABELS=$(ghr label list --json name -q '.[].name' || true)

    ACTIVE=""
    INACTIVE=""

    while IFS= read -r label; do
        if echo "$CURRENT_LABELS" | grep -Fxq "$label"; then
            ACTIVE+="$label"$'\n'
        else
            INACTIVE+="# $label"$'\n'
        fi
    done <<< "$ALL_LABELS"

    cat > "$TMP" <<EOF
# [TITLE] $TITLE

## Body
$BODY

## Labels
$ACTIVE$INACTIVE
EOF

    ORIGINAL_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    "${VISUAL:-${EDITOR:-hx}}" "$TMP"

    NEW_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    if [ "$ORIGINAL_HASH" = "$NEW_HASH" ]; then
        echo "[CANCEL] Nenhuma alteração"
        SUCCESS=1
        exit 0
    fi

    NEW_TITLE=$(sed -n 's/^# \[TITLE\] //p' "$TMP")

    NEW_BODY=$(awk '
    /## Body/ {flag=1; next}
    /## Labels/ {flag=0}
    flag
    ' "$TMP")

    NEW_LABELS=$(awk '
    /## Labels/ {flag=1; next}
    flag && $0 !~ /^#/ && NF
    ' "$TMP")

    [ -z "$NEW_TITLE" ] && { echo "[ERROR] Título vazio"; exit 1; }

    BODY_FILE="/tmp/ghi-body-$issue.txt"
    printf "%s\n" "$NEW_BODY" > "$BODY_FILE"

    TO_ADD=$(comm -13 <(echo "$CURRENT_LABELS" | sort) <(echo "$NEW_LABELS" | sort) || true)
    TO_REMOVE=$(comm -23 <(echo "$CURRENT_LABELS" | sort) <(echo "$NEW_LABELS" | sort) || true)

    ARGS=()
    ARGS+=(--title "$NEW_TITLE")
    ARGS+=(--body-file "$BODY_FILE")

    if [ -n "$TO_REMOVE" ]; then
        while IFS= read -r label; do
            [ -n "$label" ] && ARGS+=(--remove-label "$label")
        done <<< "$TO_REMOVE"
    fi

    if [ -n "$TO_ADD" ]; then
        while IFS= read -r label; do
            [ -n "$label" ] && ARGS+=(--add-label "$label")
        done <<< "$TO_ADD"
    fi

    ghr issue edit "$issue" "${ARGS[@]}"
    issue_cache

    SUCCESS=1
    echo "[OK] Issue atualizada"
}

issue_new() {
    TMP="/tmp/gh-new-issue-$(date +%s).md"

    echo "[INFO] Temp file: $TMP"

    SUCCESS=0
    trap 'if [ "${SUCCESS:-0}" -eq 0 ]; then cleanup_msg "$TMP"; fi' EXIT

    LABEL_BLOCK=""
    if ghr repo view &>/dev/null; then
        while IFS= read -r label; do
            LABEL_BLOCK+="# $label"$'\n'
        done < <(ghr label list --json name -q '.[].name')
    fi

    cat > "$TMP" <<EOF
# [TITLE]

## Body

## Labels
$LABEL_BLOCK
EOF

    ORIGINAL_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    "${VISUAL:-${EDITOR:-hx}}" "$TMP"

    NEW_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    if [ "$ORIGINAL_HASH" = "$NEW_HASH" ]; then
        echo "[CANCEL] Nenhuma alteração"
        SUCCESS=1
        exit 0
    fi

    TITLE=$(sed -n 's/^# \[TITLE\] //p' "$TMP")

    BODY=$(awk '
    /## Body/ {flag=1; next}
    /## Labels/ {flag=0}
    flag
    ' "$TMP")

    LABELS=$(awk '
    /## Labels/ {flag=1; next}
    flag && $0 !~ /^#/ && NF
    ' "$TMP")

    [ -z "$TITLE" ] && { echo "[ERROR] Título vazio"; exit 1; }

    BODY_FILE="/tmp/ghi-body-new.txt"
    printf "%s\n" "$BODY" > "$BODY_FILE"

    if [ -n "$LABELS" ]; then
        ARGS=()
        while IFS= read -r label; do
            ARGS+=(--label "$label")
        done <<< "$LABELS"

        ghr issue create --title "$TITLE" --body-file "$BODY_FILE" "${ARGS[@]}"
    else
        ghr issue create --title "$TITLE" --body-file "$BODY_FILE"
    fi

    issue_cache

    SUCCESS=1
    echo "[OK] Issue criada"
}

fzf_menu() {
    cache_valid || issue_cache

    issue_list | \
        fzf \
            --layout=reverse \
            --border=rounded \
            --cycle \
            --header "ENTER:view | CTRL-Alt [E:dit | N:ew | W:eb | C:lose | R:eopen | U:update]" \
            --info=inline \
            --pointer="▶" \
            --preview "$0 ${REPO:+-R $REPO} preview {1}" \
            --preview-window=right:50%:wrap:border-left \
            --bind "enter:become($0 ${REPO:+-R $REPO} view {1})" \
            --bind "ctrl-alt-e:execute($0 ${REPO:+-R $REPO} edit {1})+reload($0 ${REPO:+-R $REPO} list)" \
            --bind "ctrl-alt-n:execute($0 ${REPO:+-R $REPO} new)+reload($0 ${REPO:+-R $REPO} list)" \
            --bind "ctrl-alt-c:execute(ghr issue close {1})+reload($0 ${REPO:+-R $REPO} list)" \
            --bind "ctrl-alt-r:execute(ghr issue reopen {1})+reload($0 ${REPO:+-R $REPO} list)" \
            --bind "ctrl-alt-w:execute(ghr issue view {1} --web)" \
            --bind "ctrl-alt-u:execute($0 ${REPO:+-R $REPO} cache)+reload($0 ${REPO:+-R $REPO} list)"
}

case "${1:-menu}" in
    list) issue_list ;;
    view) issue_view "$2" ;;
    edit) issue_edit "$2" ;;
    new)  issue_new ;;
    preview) issue_preview "$2" ;;
    cache) issue_cache ;;
    menu) fzf_menu ;;
    *) echo "Uso: ghi [-R owner/repo] [menu|list|view N|edit N|new]" ;;
esac
