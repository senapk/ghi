#!/usr/bin/env bash
set -euo pipefail

REPO=""

if [[ "${1:-}" == "-R" ]]; then
    REPO="$2"
    shift 2
fi


CACHE_DIR="/tmp/ghi"
mkdir -p "$CACHE_DIR"

cache_file() {
    if [ -n "$REPO" ]; then
        echo "$CACHE_DIR/cache-${REPO//\//_}.json"
    else
        echo "$CACHE_DIR/cache-local.json"
    fi
}

issue_cache() {
    local CACHE
    CACHE=$(cache_file)

    echo "[INFO] Atualizando cache..." >&2

    SINCE=$(date -d '7 days ago' +%Y-%m-%d)

    {
        gh ${REPO:+-R $REPO} issue list \
            --state open \
            --limit 200 \
            --json number,title,body,labels,state,updatedAt,closedAt

        gh ${REPO:+-R $REPO} issue list \
            --state closed \
            --search "closed:>=$SINCE" \
            --limit 200 \
            --json number,title,body,labels,state,updatedAt,closedAt
    } | jq -s 'add | sort_by(.updatedAt) | reverse' > "$CACHE"

    date +%s > "${CACHE}.time"
}

cache_valid() {
    local CACHE
    CACHE=$(cache_file)

    if [ ! -f "$CACHE" ] || [ ! -f "${CACHE}.time" ]; then
        return 1
    fi

    local NOW
    NOW=$(date +%s)
    local LAST
    LAST=$(cat "${CACHE}.time")

    local AGE=$((NOW - LAST))
    [ "$AGE" -gt 300 ] && return 1

    return 0
}

tmp_file() {
    echo "/tmp/gh-issue-$1-$(date +%s).md"
}

cleanup_msg() {
    local file="$1"
    echo
    echo "[RECOVER] Arquivo salvo em: $file"
}

issue_list() {
    local CACHE
    CACHE=$(cache_file)

    if ! cache_valid; then
        issue_cache
    fi

    jq -r '
    .[]
    | "\(.number)\t:\(.state)\t\(.labels | map(.name) | join(","))\t\(.title)"
    ' "$CACHE" | column -t -s $'\t'
}

issue_preview() {
    local num="$1"
    local CACHE
    CACHE=$(cache_file)

    jq -r ".[] | select(.number==$num) |
    \"# \(.title)\n\nState: \(.state)\n\n\(.body)\n\nLabels: \(.labels | map(.name) | join(\", \"))\"" "$CACHE"
}

issue_view() {
    gh ${REPO:+-R $REPO} issue view "$1"
}

get_repo_labels() {
    if [ -n "$REPO" ]; then
        gh label list -R "$REPO" --json name -q '.[].name' 2>/dev/null || true
    else
        gh label list --json name -q '.[].name' 2>/dev/null || true
    fi
}

build_label_block() {
    local selected_labels="$1"
    local all_labels
    local block=""

    all_labels=$(get_repo_labels | sort)

    while IFS= read -r label; do
        if echo "$selected_labels" | grep -Fxq "$label"; then
            block+="[x] $label"$'\n'
        else
            block+="[ ] $label"$'\n'
        fi
    done <<< "$all_labels"

    echo "$block"
}

create_draft_issue() {
    local title="$1"
    local body="$2"
    local labels="$3"

    cat <<EOF
# [TITLE] $title

## Body
$body

## Labels
$labels

## End
EOF
}

issue_edit() {
    local issue="$1"
    TMP=$(tmp_file "$issue")   # TMP global para trap

    echo "[INFO] Temp file: $TMP"

    SUCCESS=0
    trap 'if [ "${SUCCESS:-0}" -eq 0 ]; then cleanup_msg "$TMP"; fi' EXIT

    DATA=$(gh ${REPO:+-R $REPO} issue view "$issue" --json title,body,labels)

    TITLE=$(echo "$DATA" | jq -r .title)
    BODY=$(echo "$DATA" | jq -r .body)
    CURRENT_LABELS=$(echo "$DATA" | jq -r '.labels[].name')
    CURRENT_LABELS=$(echo "$DATA" | jq -r '.labels[].name')

    LABEL_BLOCK=$(build_label_block "$CURRENT_LABELS")
    create_draft_issue "$TITLE" "$BODY" "$LABEL_BLOCK" > "$TMP"

    ORIGINAL_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    "${VISUAL:-${EDITOR:-hx}}" "$TMP"

    NEW_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    if [ "$ORIGINAL_HASH" = "$NEW_HASH" ]; then
        echo "[CANCEL] Nenhuma alteração"
        SUCCESS=1
        exit 0
    fi

    NEW_TITLE=$(sed -n 's/^# \[TITLE\] //p' "$TMP")

    NEW_BODY=$(awk '
    /## Body/ {flag=1; next}
    /## Labels/ {flag=0}
    flag
    ' "$TMP")

    NEW_LABELS=$(awk '
    /## Labels/ {flag=1; next}
    /## End/ {flag=0}
    flag && /^\[x\]/
    ' "$TMP" | sed 's/^\[x\] //')

    [ -z "$NEW_TITLE" ] && { echo "[ERROR] Título vazio"; exit 1; }

    BODY_FILE="/tmp/ghi-body-$issue.txt"
    printf "%s\n" "$NEW_BODY" > "$BODY_FILE"

    TO_ADD=$(comm -13 <(echo "$CURRENT_LABELS" | sort) <(echo "$NEW_LABELS" | sort) || true)
    TO_REMOVE=$(comm -23 <(echo "$CURRENT_LABELS" | sort) <(echo "$NEW_LABELS" | sort) || true)

    ARGS=()
    ARGS+=(--title "$NEW_TITLE")
    ARGS+=(--body-file "$BODY_FILE")

    if [ -n "$TO_REMOVE" ]; then
        while IFS= read -r label; do
            [ -n "$label" ] && ARGS+=(--remove-label "$label")
        done <<< "$TO_REMOVE"
    fi

    if [ -n "$TO_ADD" ]; then
        while IFS= read -r label; do
            [ -n "$label" ] && ARGS+=(--add-label "$label")
        done <<< "$TO_ADD"
    fi

    gh ${REPO:+-R $REPO} issue edit "$issue" "${ARGS[@]}"
    issue_cache

    SUCCESS=1
    echo "[OK] Issue atualizada"
}

issue_new() {
    TMP="/tmp/gh-new-issue-$(date +%s).md"

    echo "[INFO] Temp file: $TMP"

    SUCCESS=0
    trap 'if [ "${SUCCESS:-0}" -eq 0 ]; then cleanup_msg "$TMP"; fi' EXIT

    LABEL_BLOCK=$(build_label_block "")
    create_draft_issue "Digite o título da issue aqui" "" "$LABEL_BLOCK" > "$TMP"

    ORIGINAL_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    "${VISUAL:-${EDITOR:-hx}}" "$TMP"

    NEW_HASH=$(sha1sum "$TMP" | awk '{print $1}')

    if [ "$ORIGINAL_HASH" = "$NEW_HASH" ]; then
        echo "[CANCEL] Nenhuma alteração"
        SUCCESS=1
        exit 0
    fi

    TITLE=$(sed -n 's/^# \[TITLE\] //p' "$TMP")

    BODY=$(awk '
    /## Body/ {flag=1; next}
    /## Labels/ {flag=0}
    flag
    ' "$TMP")

    LABELS=$(awk '
    /## Labels/ {flag=1; next}
    /## End/ {flag=0}
    flag && /^\[x\]/
    ' "$TMP" | sed 's/^\[x\] //')

    [ -z "$TITLE" ] && { echo "[ERROR] Título vazio"; exit 1; }

    BODY_FILE="/tmp/ghi-body-new.txt"
    printf "%s\n" "$BODY" > "$BODY_FILE"

    if [ -n "$LABELS" ]; then
        ARGS=()
        while IFS= read -r label; do
            ARGS+=(--label "$label")
        done <<< "$LABELS"

        gh ${REPO:+-R $REPO} issue create --title "$TITLE" --body-file "$BODY_FILE" "${ARGS[@]}"
    else
        gh ${REPO:+-R $REPO} issue create --title "$TITLE" --body-file "$BODY_FILE"
    fi

    issue_cache

    SUCCESS=1
    echo "[OK] Issue criada"
}

fzf_menu() {
    cache_valid || issue_cache

    issue_list | \
        fzf \
            --layout=reverse \
            --border=rounded \
            --cycle \
            --header "Enter:toggle painel, C-Alt[Edit|New|View|Web|Close|Open|Update]" \
            --info=inline \
            --pointer="▶" \
            --exact \
            --query=":open " \
            --preview "$0 ${REPO:+-R $REPO} preview {1}" \
            --preview-window=right:50%:wrap:border-left \
            --bind "enter:toggle-preview" \
            --bind "ctrl-alt-v:become($0 ${REPO:+-R $REPO} view {1})" \
            --bind "ctrl-alt-e:execute($0 ${REPO:+-R $REPO} edit {1})+reload($0 ${REPO:+-R $REPO} list)" \
            --bind "ctrl-alt-n:execute($0 ${REPO:+-R $REPO} new)+reload($0 ${REPO:+-R $REPO} list)" \
            --bind "ctrl-alt-c:execute(gh ${REPO:+-R $REPO} issue close {1})+reload($0 ${REPO:+-R $REPO} list-refresh)" \
            --bind "ctrl-alt-o:execute(gh ${REPO:+-R $REPO} issue reopen {1})+reload($0 ${REPO:+-R $REPO} list-refresh)" \
            --bind "ctrl-alt-w:execute-silent(nohup gh ${REPO:+-R $REPO} issue view {1} --web >/dev/null 2>&1 &)" \
            --bind "ctrl-alt-u:reload($0 ${REPO:+-R $REPO} list-refresh)"
}

case "${1:-menu}" in
    list) issue_list ;;
    view) issue_view "$2" ;;
    edit) issue_edit "$2" ;;
    new)  issue_new ;;
    preview) issue_preview "$2" ;;
    cache) issue_cache ;;
    menu) fzf_menu ;;
    list-refresh)
        issue_cache
        issue_list
        ;;
    *) echo "Uso: ghi [-R owner/repo] [menu|list|view N|edit N|new]" ;;
esac
